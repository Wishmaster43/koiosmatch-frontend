{
  "name": "koiosmatch-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "gen:types": "npx -y openapi-typescript@7 ../koiosmatch-api/docs/openapi.yaml -o src/types/api-generated.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "git config core.hooksPath .githooks || true",
    "smoke": "node e2e/run.mjs",
    "smoke:career": "node e2e/careersite.mjs",
    "dev:career": "vite --config careersite/vite.config.ts",
    "build:career": "vite build --config careersite/vite.config.ts",
    "test:career": "vitest run --config careersite/vite.config.ts"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.5",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@types/leaflet": "^1.9.21",
    "@xyflow/react": "^12.11.0",
    "axios": "^1.17.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.10",
    "i18next": "^26.3.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^6.1.200",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.12",
    "vitest": "^2.1.9"
  }
}
