# Copy this file to .env and adjust per environment.
# API base URL the frontend talks to. MUST be https in production (see security #3).
VITE_API_URL=http://koiosmatch-api.test/api

# Auth: httpOnly cookie + CSRF is the ONLY mode (H3, 2026-07-08) — the legacy
# Bearer flow was removed from the code; no env var can re-enable it.
# CSRF cookie endpoint (Laravel Sanctum). Defaults to <api-root>/sanctum/csrf-cookie.
# VITE_CSRF_URL=http://koiosmatch-api.test/sanctum/csrf-cookie

# Show seeded demo data when the API returns nothing. NEVER enable in production —
# it is force-disabled in prod builds regardless. Local demo only.
VITE_USE_MOCKS=false
