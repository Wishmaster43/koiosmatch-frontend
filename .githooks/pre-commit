#!/bin/sh
# PROC-1 gate — no red main. Blocks a commit that breaks typecheck or lint (the
# exact class of failure that slipped in on 2026-07-01: a file passing vitest but
# breaking `tsc`). Runs the same checks as CI. Real emergency escape: --no-verify.
#
# Shared without husky: package.json's "prepare" points git at .githooks via
# core.hooksPath, so every clone/install gets this gate.

echo "▶ pre-commit: typecheck…"
npm run --silent typecheck || {
  echo "✗ tsc failed — fix the type errors before committing (or, only if you must: git commit --no-verify)"
  exit 1
}
echo "▶ pre-commit: lint…"
npm run --silent lint || {
  echo "✗ eslint reported errors — fix them before committing"
  exit 1
}
echo "▶ pre-commit: i18n parity…"
npx vitest run src/i18n/localeParity.test.ts || {
  echo "✗ i18n parity failed — a locale (de/fr/es/en) is missing keys nl has. Add them (all 5 locales) before committing."
  exit 1
}
# gen:types freshness (C-CHIP #4): api-generated.ts must match the backend spec.
# Regenerates when the sibling spec exists; a diff means the contract moved — the
# regenerated file is left in place: `git add src/types/api-generated.ts` and retry.
if [ -f ../koiosmatch-api/docs/openapi.yaml ]; then
  echo "▶ pre-commit: gen:types freshness…"
  npm run --silent gen:types >/dev/null 2>&1
  if ! git diff --quiet src/types/api-generated.ts; then
    echo "✗ api-generated.ts was behind the spec — just regenerated: git add src/types/api-generated.ts and commit again"
    exit 1
  fi
fi
echo "✓ gate passed (tsc 0, lint 0 errors, i18n parity, types fresh)"
