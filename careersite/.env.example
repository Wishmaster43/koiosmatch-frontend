# Public career-site env vars — VITE_* is always exposed to the client (CLAUDE.md §7),
# so nothing secret belongs here. Copy to `.env` for local overrides.

# Base of the public career API, WITHOUT the trailing /public/{tenant} — the client
# appends that itself. Defaults to the local Herd dev host when unset.
VITE_CAREER_API_URL=http://koiosmatch-api.test/api

# Deploy sub-path for the built assets (Vite's `base`). Use '/' for a plain domain root.
VITE_CAREER_BASE=/
